@page
@model CreateModel
@{
    ViewData["Title"] = "Thêm chương học";
}

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-plus-circle-fill me-2"></i>
        @ViewData["Title"]
    </h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-custom">
            <div class="card-custom-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
                    }

                    <div class="mb-4">
                        <label asp-for="Input.SubjectID" class="form-label fw-semibold"></label>
                        <select asp-for="Input.SubjectID" class="form-select" id="subjectSelect">
                            <option value="">— Chọn môn học —</option>
                            @foreach (var s in Model.Input.Subjects)
                            {
                                <option value="@s.SubjectID">[@s.SubjectCode] @s.SubjectName</option>
                            }
                        </select>
                        <span asp-validation-for="Input.SubjectID" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ChapterNumber" class="form-label fw-semibold"></label>
                        <input asp-for="Input.ChapterNumber" class="form-control form-control-lg" type="number" min="1" max="100" placeholder="VD: 1"/>
                        <span asp-validation-for="Input.ChapterNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ChapterName" class="form-label fw-semibold"></label>
                        <input asp-for="Input.ChapterName" class="form-control form-control-lg" placeholder="VD: Lập trình OOP căn bản"/>
                        <span asp-validation-for="Input.ChapterName" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-1"></i>
                            Tạo chương học
                        </button>
                        <a asp-page="./Index" asp-route-subjectId="@Model.Input.SubjectID" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function getSubjectValue(subject, key) {
            const pascalKey = key.charAt(0).toUpperCase() + key.slice(1);
            const idKey = key.endsWith('Id') ? key.slice(0, -2) + 'ID' : key;
            return subject[key] ?? subject[pascalKey] ?? subject[idKey] ?? subject[idKey.charAt(0).toUpperCase() + idKey.slice(1)];
        }

        function subjectOptionText(subject) {
            return `[${getSubjectValue(subject, 'subjectCode')}] ${getSubjectValue(subject, 'subjectName')}`;
        }

        function upsertSubjectOption(subject) {
            const select = document.getElementById('subjectSelect');
            if (!select) return;

            const id = String(getSubjectValue(subject, 'subjectId'));
            const text = subjectOptionText(subject);
            let option = Array.from(select.options).find(o => o.value === id);

            if (!option) {
                option = new Option(text, id);
                select.add(option);
            } else {
                option.text = text;
            }
        }

        function removeSubjectOption(payload) {
            const select = document.getElementById('subjectSelect');
            if (!select) return;

            const id = String(getSubjectValue(payload, 'subjectId'));
            const option = Array.from(select.options).find(o => o.value === id);
            if (option) option.remove();
        }

        document.addEventListener("realtimeUpdate", function(e) {
            const type = e.detail.messageType;
            const payload = e.detail.payload;

            if (type === "SubjectCreated" || type === "SubjectUpdated") upsertSubjectOption(payload);
            else if (type === "SubjectDeleted") removeSubjectOption(payload);
        });
    </script>
}
