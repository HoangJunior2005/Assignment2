@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = "Chi tiết Whitelist Email";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title"><i class="bi bi-envelope-check-fill me-2"></i>Chi tiết Whitelist Email</h1>
        <p class="page-subtitle">Thông tin chi tiết về địa chỉ whitelist @Model.EmailData.Email</p>
    </div>
    <div>
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card-custom">
            <div class="card-custom-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Mã số (ID)</dt>
                    <dd class="col-sm-8 fw-semibold">#@Model.EmailData.Id</dd>

                    <dt class="col-sm-4 text-muted">Địa chỉ Email</dt>
                    <dd class="col-sm-8">@Model.EmailData.Email</dd>

                    <dt class="col-sm-4 text-muted">Trạng thái sử dụng</dt>
                    <dd class="col-sm-8">
                        @if (Model.EmailData.IsUsed)
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle">
                                <i class="bi bi-check-circle-fill me-1"></i>Đã sử dụng để đăng ký
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                                <i class="bi bi-hourglass-split me-1"></i>Chưa sử dụng
                            </span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted">Ngày whitelist</dt>
                    <dd class="col-sm-8 text-muted">@Model.EmailData.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
