@page
@model IndexModel
@{
    ViewData["Title"] = "Môn học";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-book-fill me-2"></i>Môn học</h1>
        <p class="page-subtitle">Quản lý các môn học trong hệ thống</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-page="/Subjects/Create" class="btn btn-primary btn-action">
            <i class="bi bi-plus-circle me-2"></i>Thêm môn học
        </a>
    }
</div>

<div class="card-custom">
    <div class="card-custom-body p-0">
        @if (!Model.Subjects.Any())
        {
            <div class="empty-state py-5">
                <i class="bi bi-journal-x"></i>
                <p>Chưa có môn học nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-clean mb-0 align-middle">
                    <thead class="table-light text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                        <tr>
                            <th>#</th>
                            <th>Tên môn học</th>
                            <th>Mã học phần</th>
                            <th>Số chương</th>
                            <th>Ngày tạo</th>
                            @if (User.IsInRole("Admin")) { <th class="text-end">Thao tác</th> }
                        </tr>
                    </thead>
                    <tbody id="subjectsTableBody">
                        @{int i = 1;}
                        @foreach (var s in Model.Subjects)
                        {
                            <tr data-subject-id="@s.SubjectID">
                                <td class="text-muted">@(i++)</td>
                                <td>
                                    <a asp-page="/Chapters/Index" asp-route-subjectId="@s.SubjectID" class="doc-link fw-semibold">
                                        @s.SubjectName
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill">
                                        @s.SubjectCode
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary">
                                        <i class="bi bi-collection me-1"></i>@s.ChapterCount chương
                                    </span>
                                </td>
                                <td class="text-muted small">@s.CreatedAt.ToString("dd/MM/yyyy")</td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-page="/Subjects/Details" asp-route-id="@s.SubjectID" class="btn btn-outline-info" title="Chi tiết">
                                                <i class="bi bi-info-circle-fill"></i>
                                            </a>
                                            <a asp-page="/Subjects/Edit" asp-route-id="@s.SubjectID"
                                               class="btn btn-outline-warning" title="Sửa">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <button type="button" class="btn btn-outline-danger"
                                                    onclick="confirmDelete(@s.SubjectID, '@s.SubjectName')"
                                                    title="Xóa">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 bg-danger text-white justify-content-center position-relative">
                <h5 class="modal-title m-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Xác nhận xóa</h5>
                <button type="button" class="btn-close btn-close-white position-absolute" style="right: 1.25rem; top: 1.25rem;" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4 text-center">
                <p>Xóa môn học: <strong class="text-danger" id="delName"></strong>?</p>
                <p class="text-muted small mb-0">Sẽ xóa tất cả chương và tài liệu liên quan (CASCADE).</p>
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <button class="btn btn-secondary me-2" data-bs-dismiss="modal">Hủy</button>
                <form id="delForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash-fill me-1"></i>Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmDelete(id, name) {
        document.getElementById('delName').textContent = name;
        document.getElementById('delForm').action = '/Subjects/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }

    function getSubjectValue(subject, key) {
        const pascalKey = key.charAt(0).toUpperCase() + key.slice(1);
        const idKey = key.endsWith('Id') ? key.slice(0, -2) + 'ID' : key;
        return subject[key] ?? subject[pascalKey] ?? subject[idKey] ?? subject[idKey.charAt(0).toUpperCase() + idKey.slice(1)];
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function formatDate(value) {
        const date = value ? new Date(value) : new Date();
        if (Number.isNaN(date.getTime())) return '';
        return date.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
    }

    function renumberSubjects() {
        document.querySelectorAll('#subjectsTableBody tr').forEach((row, index) => {
            const numberCell = row.querySelector('td');
            if (numberCell) numberCell.textContent = index + 1;
        });
    }

    function renderSubjectRow(subject) {
        const id = getSubjectValue(subject, 'subjectId');
        const name = getSubjectValue(subject, 'subjectName');
        const code = getSubjectValue(subject, 'subjectCode');
        const chapterCount = getSubjectValue(subject, 'chapterCount') ?? 0;
        const createdAt = getSubjectValue(subject, 'createdAt');
        const deleteCall = `confirmDelete(${id}, ${JSON.stringify(name ?? '')})`;

        return `
            <tr data-subject-id="${escapeHtml(id)}">
                <td class="text-muted"></td>
                <td>
                    <a href="/Chapters?subjectId=${encodeURIComponent(id)}" class="doc-link fw-semibold">
                        ${escapeHtml(name)}
                    </a>
                </td>
                <td>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill">
                        ${escapeHtml(code)}
                    </span>
                </td>
                <td>
                    <span class="badge bg-secondary-subtle text-secondary">
                        <i class="bi bi-collection me-1"></i>${escapeHtml(chapterCount)} chương
                    </span>
                </td>
                <td class="text-muted small">${escapeHtml(formatDate(createdAt))}</td>
                <td class="text-end">
                    <div class="btn-group btn-group-sm">
                        <a href="/Subjects/Details/${encodeURIComponent(id)}" class="btn btn-outline-info" title="Chi tiết">
                            <i class="bi bi-info-circle-fill"></i>
                        </a>
                        <a href="/Subjects/Edit/${encodeURIComponent(id)}" class="btn btn-outline-warning" title="Sửa">
                            <i class="bi bi-pencil-fill"></i>
                        </a>
                        <button type="button" class="btn btn-outline-danger" onclick='${escapeHtml(deleteCall)}' title="Xóa">
                            <i class="bi bi-trash-fill"></i>
                        </button>
                    </div>
                </td>
            </tr>`;
    }

    function upsertSubjectRow(subject) {
        const tbody = document.getElementById('subjectsTableBody');
        if (!tbody) {
            window.location.reload();
            return;
        }

        const id = getSubjectValue(subject, 'subjectId');
        const existingRow = tbody.querySelector(`tr[data-subject-id="${CSS.escape(String(id))}"]`);
        const rowHtml = renderSubjectRow(subject).trim();

        if (existingRow) {
            existingRow.outerHTML = rowHtml;
        } else {
            tbody.insertAdjacentHTML('beforeend', rowHtml);
        }

        renumberSubjects();
    }

    function removeSubjectRow(payload) {
        const id = getSubjectValue(payload, 'subjectId');
        const row = document.querySelector(`#subjectsTableBody tr[data-subject-id="${CSS.escape(String(id))}"]`);
        if (row) {
            row.remove();
            renumberSubjects();
        }
    }

    // Realtime update listener to update subjects list without a manual refresh
    document.addEventListener("realtimeUpdate", function(e) {
        const type = e.detail.messageType;
        const payload = e.detail.payload;

        if (type === "SubjectCreated" || type === "SubjectUpdated") upsertSubjectRow(payload);
        else if (type === "SubjectDeleted") removeSubjectRow(payload);
    });
</script>
}
