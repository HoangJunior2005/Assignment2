@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title"><i class="bi bi-person-fill me-2"></i>Chi tiết tài khoản</h1>
        <p class="page-subtitle">Thông tin chi tiết về tài khoản @Model.UserData.Username</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        <a asp-page="./Edit" asp-route-id="@Model.UserData.UserID" class="btn btn-warning">
            <i class="bi bi-pencil-fill me-1"></i> Chỉnh sửa
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card-custom">
            <div class="card-custom-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Mã số người dùng (ID)</dt>
                    <dd class="col-sm-8 fw-semibold">#@Model.UserData.UserID</dd>

                    <dt class="col-sm-4 text-muted">Tên tài khoản (Email)</dt>
                    <dd class="col-sm-8">@Model.UserData.Username</dd>

                    <dt class="col-sm-4 text-muted">Họ và tên</dt>
                    <dd class="col-sm-8">@Model.UserData.FullName</dd>

                    <dt class="col-sm-4 text-muted">Vai trò (Roles)</dt>
                    <dd class="col-sm-8">
                        @foreach (var role in Model.UserData.Roles)
                        {
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill me-1">@role</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted">Quyền Upload tài liệu</dt>
                    <dd class="col-sm-8">
                        @if (Model.UserData.CanUpload)
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle"><i class="bi bi-check-lg me-1"></i>Có</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle"><i class="bi bi-x-lg me-1"></i>Không</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted">Ngày tạo</dt>
                    <dd class="col-sm-8 text-muted">@Model.UserData.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</dd>

                    <dt class="col-sm-4 text-muted">Trạng thái hoạt động</dt>
                    <dd class="col-sm-8">
                        @if (Model.UserData.IsActive)
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Đã khóa</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
